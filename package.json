{
  "name": "testing_framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jasmine",
    "build": "tsc --noEmit",
    "test:unit": "jasmine",
    "test:mutation": "stryker run",
    "metricas:complejidad": "node -r ts-node/register scripts/metricas/generarComplejidadPruebas.ts",
    "metricas:estabilidad": "node -r ts-node/register scripts/metricas/detectarPruebasInestables.ts",
    "metricas:tiempo": "node -r ts-node/register scripts/metricas/analizarTiempoEjecucion.ts",
    "test:coverage": "c8 --reporter=text --reporter=json-summary jasmine",
    "metricas:cobertura-defectos": "node -r ts-node/register scripts/metricas/generarRelacionCoberturaDefectos.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Armando2t/Testing_Framework.git"
