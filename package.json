  "bugs": {
    "url": "https://github.com/Armando2t/Testing_Framework/issues"
  },
  "homepage": "https://github.com/Armando2t/Testing_Framework#readme",
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jasmine-runner": "^9.6.1",
    "@types/jasmine": "^6.0.0",
    "c8": "^11.0.0",
    "fast-check": "^4.8.0",
    "jasmine": "^6.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
